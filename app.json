{
  "expo": {
    "name": "Abalay",
    "slug": "abalay",
    "version": "1.0.0",
    "description": "Abalay is a rental property management app that connects landlords and tenants. Landlords can list properties, manage tenants, handle contracts, track payments, and schedule maintenance. Tenants can browse properties, apply for rentals, pay bills, submit maintenance requests, and communicate with landlords in real time.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "abalay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": [
      "android",
      "ios",
      "web"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.abalay.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0c1a2e",
          "dark": {
            "backgroundColor": "#0c1a2e"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class expo.modules.kotlin.types.** { *; }\n-keep class expo.modules.notifications.** { *; }\n-dontwarn expo.modules.kotlin.types.JSTypeConverterProvider**\n-dontwarn expo.modules.kotlin.types.JSTypeConverterProvider$ContainerProvider"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set your profile picture."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2563eb",
          "defaultChannel": "default"
        }
      ],
      "expo-mail-composer"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "275e7f6a-6e1c-4953-a990-b5376e1f53de"
      }
    },
    "owner": "alfonzperez"
  }
}
